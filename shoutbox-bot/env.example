# Copy to .env next to this package and fill in values.

# Canonical room URL (same string users paste in the shoutbox UI).
# Example self-hosted room path:
# SHOUTBOX_ROOM_URL=https://shoutbox.example.com/default
SHOUTBOX_ROOM_URL=https://shoutbox.orbiter.website/

# 32-byte secp256k1 private key (0x + 64 hex). Use a dedicated empty wallet.
SHOUTBOX_BOT_PRIVATE_KEY=

# Must match the deployed app (production for shoutbox.orbiter.website).
SHOUTBOX_XMTP_ENV=production

# Optional: Gun radisk disk (`RAD=true`). Default is off; bot uses temp cwd + in-memory store + same AXE/multicast as the web app for relay sync.

# Optional: comma-separated Gun peers (defaults match the web app).
# SHOUTBOX_GUN_RELAY_PEERS=https://gun-manhattan.herokuapp.com/gun,https://gun-us.herokuapp.com/gun

# Optional: persistent SQLite path for the XMTP client.
# SHOUTBOX_BOT_DB_PATH=./shoutbox-bot.db3

# Optional: 32-byte hex key for DB encryption (0x + 64 hex).
# SHOUTBOX_BOT_DB_ENCRYPTION_KEY=

# Optional: OpenAI-compatible API (LM Studio: enable local server, note host/port in the status log).
# baseURL must include /v1 (SDK calls .../v1/chat/completions). Use 127.0.0.1:1234 or the LAN IP LM Studio prints.
# When set, the bot replies via chat completions; otherwise it uses the echo prefix in src/reply.ts.
# SHOUTBOX_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# SHOUTBOX_OPENAI_MODEL=unsloth/gemma-4-E4B-it-GGUF
# SHOUTBOX_OPENAI_API_KEY=lm-studio
# SHOUTBOX_OPENAI_SYSTEM_PROMPT=You are a helpful shoutbox bot. Stay brief.

# Optional: max recent plain-text XMTP messages to pass into the model (1–200, default 50).
# SHOUTBOX_BOT_CONTEXT_MESSAGE_LIMIT=50
