# Environment Variables
# Copy this file to .env.local and fill in the values

# Required: WalletConnect Project ID from https://dashboard.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Required: XMTP environment (dev | production)
VITE_XMTP_ENV=

# Required: Application base URL (must be a valid URL once normalized).
# Use a full URL: https://your-domain.com or http://localhost:3000
# Bare hostnames are OK: example.com becomes https://example.com; localhost:3000 becomes http://localhost:3000
VITE_APP_URL=

# Optional: Comma-separated GunDB relay peer URLs
VITE_GUN_RELAY_PEERS=

# Optional: Sliding window duration in minutes (default: 5)
VITE_SLIDING_WINDOW_MINUTES=
