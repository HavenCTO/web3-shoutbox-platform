# ── Sovereign Shoutbox Bot Configuration ──
# Copy from shoutbox-bot/.env and adjust as needed.

# Canonical room URL (must match the web app)
SHOUTBOX_ROOM_URL=https://shoutbox.example.com/default

# 32-byte secp256k1 private key (dedicated bot wallet)
SHOUTBOX_BOT_PRIVATE_KEY=0xe2c85acaa6afd479dca00d944e125b7f384fd4e9ff215536afd907cc142e8900

# Must match the web app's VITE_XMTP_ENV
SHOUTBOX_XMTP_ENV=dev

# Gun relay peers — must match the web app's VITE_GUN_RELAY_PEERS exactly
SHOUTBOX_GUN_RELAY_PEERS=https://elaine-fugal-supernumerously.ngrok-free.dev/gun,https://peer.wallie.io/gun

# Persist XMTP identity DB so key generation only happens once
SHOUTBOX_BOT_DB_PATH=./sovereign-bot.db3

# LLM provider (LM Studio for dev — no API key needed)
SHOUTBOX_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
SHOUTBOX_OPENAI_MODEL=google/gemma-4-26b-a4b
